# ============================================================
# .env.example — Copie para .env e preencha com suas chaves
# ============================================================
# NUNCA commite o arquivo .env — apenas o .env.example!
# O .env já está no .gitignore desta pasta.
#
# Alternativa: configure as chaves diretamente no terminal:
#   PowerShell: $env:ANTHROPIC_API_KEY = "sk-ant-..."
#   Bash/macOS: export ANTHROPIC_API_KEY="sk-ant-..."
#
# Ou rode o setup interativo:
#   python automation/_env.py
# ============================================================

# Chave da API Anthropic/Claude — para geração das classes ABAP
# Obtenha em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Chave da API OpenAI — para OCR de imagens dentro dos .docx (GPT-4o Vision)
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
