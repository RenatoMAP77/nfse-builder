# ============================================================
# .env.example — Copie para .env e preencha com suas credenciais
# ============================================================
# NUNCA commite o arquivo .env — apenas o .env.example!
# O .env já está no .gitignore desta pasta.
#
# Toda geração de IA usa o claude CLI local (sem API keys).
# Certifique-se de que o claude CLI está instalado:
#   npm install -g @anthropic-ai/claude-code
# ============================================================

# Credenciais SAP para deploy (opcional — apenas se usar --deploy)
SAP_URL=http://seu-servidor:8000
SAP_USER=seu_usuario
SAP_PASSWORD=sua_senha
SAP_CLIENT=400
